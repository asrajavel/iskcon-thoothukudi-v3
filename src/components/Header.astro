---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const donateUrl = 'https://pages.razorpay.com/ISKCON-KVA-DONATION';

const navItems = [
  { label: 'Home', href: `${base}/` },
  { label: 'About', href: `${base}/about` },
  { label: 'Sevas', href: `${base}/sevas` },
  { label: 'Courses', href: `${base}/courses` },
  { label: 'Events', href: `${base}/events` },
  { label: 'Contact', href: `${base}/contact` },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-border sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`${base}/`} class="flex items-center gap-3">
      <img src="https://iskconmumbaipull-21250.kxcdn.com/bi_theme_snippets/static/src/img/logo-black-header.png" alt="ISKCON" class="h-10 w-auto" />
      <span class="text-sm font-medium text-dark tracking-wide uppercase">ISKCON Thoothukudi</span>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'px-3 py-2 text-xs tracking-wide uppercase transition-colors',
            currentPath === item.href
              ? 'text-dark font-bold'
              : 'text-muted hover:text-dark',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="ml-3 px-5 py-2 bg-sage text-white text-xs font-medium uppercase tracking-wide hover:bg-sage-dark transition-colors">
        Donate
      </a>
    </nav>
    <button id="mobile-menu-btn" class="md:hidden p-2 text-dark" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
  <nav id="mobile-menu" class="md:hidden hidden border-t border-border px-6 pb-4 bg-white">
    {navItems.map(item => (
      <a
        href={item.href}
        class:list={[
          'block py-3 text-xs uppercase tracking-wide border-b border-border last:border-0',
          currentPath === item.href ? 'text-dark font-bold' : 'text-muted hover:text-dark',
        ]}
      >
        {item.label}
      </a>
    ))}
    <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="block mt-3 text-center px-5 py-2.5 bg-sage text-white text-xs font-medium uppercase tracking-wide hover:bg-sage-dark transition-colors">
      Donate
    </a>
  </nav>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
