---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with ISKCON Thoothukudi">
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="text-4xl md:text-5xl font-bold text-dark mb-3">Contact Us</h1>
    <p class="text-muted text-lg max-w-xl mb-16 leading-relaxed">
      We'd love to hear from you. Visit us, call us, or send us a message.
    </p>

    <div class="grid md:grid-cols-2 gap-16">
      <!-- Contact Info -->
      <div class="space-y-10">
        <div>
          <h2 class="text-xs font-bold uppercase tracking-widest text-dark mb-4">Temple Address</h2>
          <p class="text-muted leading-relaxed">
            ISKCON Thoothukudi<br />
            Hare Krishna Land<br />
            Thoothukudi - 628001<br />
            Tamil Nadu, India
          </p>
        </div>

        <div>
          <h2 class="text-xs font-bold uppercase tracking-widest text-dark mb-4">Get in Touch</h2>
          <div class="space-y-3 text-muted">
            <p class="flex items-center gap-3">
              <svg class="w-4 h-4 text-taupe" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              +91 98765 43210
            </p>
            <p class="flex items-center gap-3">
              <svg class="w-4 h-4 text-taupe" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              info@iskconthoothukudi.com
            </p>
          </div>
        </div>

        <div>
          <h2 class="text-xs font-bold uppercase tracking-widest text-dark mb-4">Temple Timings</h2>
          <div class="text-sm text-muted space-y-3">
            <div class="flex justify-between border-b border-border pb-3">
              <span>Mangala Arati</span><span class="font-medium text-dark">4:30 AM</span>
            </div>
            <div class="flex justify-between border-b border-border pb-3">
              <span>Darshan Opens</span><span class="font-medium text-dark">7:00 AM</span>
            </div>
            <div class="flex justify-between border-b border-border pb-3">
              <span>Raj Bhog Arati</span><span class="font-medium text-dark">12:30 PM</span>
            </div>
            <div class="flex justify-between border-b border-border pb-3">
              <span>Evening Darshan</span><span class="font-medium text-dark">4:00 PM</span>
            </div>
            <div class="flex justify-between border-b border-border pb-3">
              <span>Sandhya Arati</span><span class="font-medium text-dark">7:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span>Temple Closes</span><span class="font-medium text-dark">8:30 PM</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <h2 class="text-xs font-bold uppercase tracking-widest text-dark mb-6">Send us a Message</h2>
        <form class="space-y-5">
          <div>
            <label class="block text-sm font-medium text-dark mb-2" for="name">Name</label>
            <input type="text" id="name" class="w-full border border-border px-4 py-3 text-sm focus:ring-1 focus:ring-sage focus:border-sage outline-none transition-colors bg-white" placeholder="Your name" />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-2" for="phone">Phone</label>
            <input type="tel" id="phone" class="w-full border border-border px-4 py-3 text-sm focus:ring-1 focus:ring-sage focus:border-sage outline-none transition-colors bg-white" placeholder="+91 ..." />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-2" for="email">Email (optional)</label>
            <input type="email" id="email" class="w-full border border-border px-4 py-3 text-sm focus:ring-1 focus:ring-sage focus:border-sage outline-none transition-colors bg-white" placeholder="your@email.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-2" for="subject">Subject</label>
            <select id="subject" class="w-full border border-border px-4 py-3 text-sm focus:ring-1 focus:ring-sage focus:border-sage outline-none transition-colors bg-white">
              <option>General Enquiry</option>
              <option>Seva Booking</option>
              <option>Course Registration</option>
              <option>Donation</option>
              <option>Volunteer</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-2" for="message">Message</label>
            <textarea id="message" rows="5" class="w-full border border-border px-4 py-3 text-sm focus:ring-1 focus:ring-sage focus:border-sage outline-none transition-colors bg-white" placeholder="How can we help you?"></textarea>
          </div>
          <button type="submit" class="w-full bg-sage hover:bg-sage-dark text-white py-3 text-sm font-medium uppercase tracking-wide transition-colors">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
